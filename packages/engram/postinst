#!/data/data/com.termux/files/usr/bin/bash
IFS=$'\n\t'

echo "Cloning repository ..."
git clone --quiet https://github.com/Gentleman-Programming/engram ${HOME}/.local/share/engram

[[ -d ${HOME}/.local/share/engram ]] && {
    echo "Installing requirements ...";
    cd engram
    go install ./cmd/engram
    chmod 751 -R ${HOME}/.local/share/engram;
    if [[ -f ${HOME}/go/bin/engram ]]; then
        echo "[✔] engram installation finished."
        echo "[💡] Run 'engram serve' to init init the server."
        echo "[💡] Run 'engram setup <AI agent name>' to setup your agent."
        echo "[➡] Run 'engram' to execute it."
    fi
} || {
  echo -en "\e[31mE:\e[0m engram directory missing ... \e[33mAborting.\e[0m\n";
}

# ==============================
# INSTALLING SCRIPT FIXER
# ==============================
echo "[*] Installing script fixer..."
fixerURL="https://raw.githubusercontent.com/ivam3/i-Haklab/master/.deb/home/.local/bin/fixer"
if curl -fsSL "$fixerURL" -o /data/data/com.termux/files/usr/bin/fixer; then
    chmod 750 /data/data/com.termux/files/usr/bin/fixer
    echo "[➡] Run 'fixer' to fix any posible issue."
else
    echo "[!] Error downloading fixer."
fi

# ==============================
# FINALS MESSAGES
# ==============================
echo "[📢] Help: going to https://t.me/Ivam3_Bot."
echo "[💡] @Ivam3: thank you for use my package."
