#!/data/data/com.termux/files/usr/bin/bash
# VARIABLES
burpVer="2026.1.5" ##THE LASTEST COMPATIBLE VERSION FOR TERMUX
lv="9.1.0"

echo "Downloading jar files (It could take a while) ..."
wget "https://portswigger.net/burp/releases/download?product=community&version=${burpVer}&type=Jar" \
	-O ${HOME}/.local/share/burpsuite.jar

if [[ -e ${HOME}/.local/share/burpsuite.jar ]]; then
  echo "Installing requirements ..."
  chmod 751 ${HOME}/.local/share/burpsuite.jar
  # LIBGIF VERSION SPECIFIC NEEDED 
  [[ ! -e $PREFIX/opt/openjdk/lib/libgif.so.7 ]] && [[ -e $PREFIX/lib/libgif.so.$lv ]] && {
    ln -s $PRERIX/lib/libgif.so.$lv $PREFIX/opt/openjdk/lib/libgif.so.7;
  }
  echo "[*] burpsuite installation finished."
  echo "[!] Burpsuite is not a CLi tool."
  echo "[!] A desktop enviroment needed"
  echo "[*] Run 'burpsuite' to execute it."

else
  echo -en "\e[31mE:\e[0m burpsuite jar file missing ... \e[33mAborting.\e[0m\n"

fi

# ==============================
# INSTALLING SCRIPT FIXER
# ==============================
echo "[*] Installing script fixer..."
fixerURL="https://raw.githubusercontent.com/ivam3/i-Haklab/master/.deb/home/.local/bin/fixer"
if curl -fsSL "$fixerURL" -o /data/data/com.termux/files/usr/bin/fixer; then
    chmod 750 /data/data/com.termux/files/usr/bin/fixer
    echo "[➡] Run 'fixer' to fix any posible issue."
else
    echo "[!] Error downloading fixer."
fi

# ==============================
# FINALS MESSAGES
# ==============================
echo "[📢] Help: going to https://t.me/Ivam3_Bot."
echo "[💡] @Ivam3: thank you for use my package."
