#!/data/data/com.termux/files/usr/bin/bash
# COLORS
W="\e[0m"
R="\e[31m"
G="\e[32m"
Y="\e[33m"
B="\e[34m"

ip="$(ifconfig 2>/dev/null|grep -oE '([0-9]{1,3}\.){3}'|grep -v 255|grep -v 127|tail -n 1)"
[[ -z "$ip" ]] && ip="10.0.2."

bannerReadme(){
      printf "\e[33m"
      echo '''
     ____  _____    _    ____  __  __ _____
    |  _ \| ____|  / \  |  _ \|  \/  | ____|
    | |_) |  _|   / _ \ | | | | |\/| |  _|
    |  _ <| |___ / ___ \| |_| | |  | | |___
    |_| \_\_____/_/   \_\____/|_|  |_|_____|
    ::::::::::::::::::::::::::::::::::::::::'''
}


install(){
    # Create main dir 
    echo "[*] Preparando instalación de $os..."
    mkdir -p ${HOME}/.local/share/termux-docker-qemu/$os/termux2$os 2>/dev/null
    cd ${HOME}/.local/share/termux-docker-qemu/$os
    
    # Download iso
    [[ -e $iso ]] && { echo "[!] Usando ISO existente."; } || {
        echo "[+] Descargando $os ISO ($iso)..."
        wget --tries=20 --quiet --progress=dot $ref$iso -O $iso
    }
  
    # Create disk
    while read -n 3 -p "ROM size [recommended in gigas: 30]? " size && [[ ! ${size} =~ ^[1-9] ]]; do 
        [[ -z ${size} ]] && { break;} || { echo "E: Invalid answer";}
    done 
    while read -n 3 -p "RAM size [recommended in gigas: 12]? " mRAM && [[ ! ${mRAM} =~ ^[1-9] ]]; do 
        if [[ -z ${mRAM} ]]; then 
            break 
        else 
            echo -en "\e[31mE:\e[0m Invalid answer\n" 
        fi 
    done 

    [[ -z $mRAM ]] && { mRAM="12288"; } || { mRAM=$(expr 1024 \* $mRAM);} 
    
    # Actualizar RAM en el script ejecutable si existe
    [[ -f ${PREFIX}/bin/termux-docker-qemu ]] && sed -i "s/mRAM=.*/mRAM=\"$mRAM\"/" ${PREFIX}/bin/termux-docker-qemu
  
    echo "[+] Creando imagen QCOW2 (Optimización VirtIO)."
    [[ -f $os.qcow2 ]] && rm -f $os.qcow2
    [[ -z $size ]] && { size="30G"; } || { size=$size'G';}
    qemu-img create -f qcow2 $os.qcow2 $size

    if [[ $os = alpine ]]; then
        bannerReadme 
        echo -en "\e[0mBoot process will start, in middle of it you will login to Linux OS
      Do it as \e[31mroot\e[0m user.
      Once in OS terminal run one by one the next commands:

        $ setup-interfaces
        ╰─➤# On it response at all question pressing 'enter' for default settings
        $ ifup eth0
        $ echo -en \"nameserver 8.8.8.8\" >> /etc/resolv.conf
        $ wget https://raw.githubusercontent.com/ivam3/termux-packages/gh-pages/packages/termux-docker-qemu/ashrc.sh -O /etc/profile.d/ashrc.sh
        $ wget https://raw.githubusercontent.com/ivam3/termux-packages/gh-pages/packages/termux-docker-qemu/answerfile.$os
        $ apk add tzdata
        $ setup-$os -f answerfile.$os
        ╰─➤# It will ask you to set a new password
        ╰─➤# Respond with 'no' On question 'Setup a user?'
        ╰─➤# Respond with 'y' On question 'erase the above disk(s) and continue? [y/N]:'
        $ poweroff

      [!] Or if you prefer just copy and paste the next one-command-line (FAST VIRTIO INSTALL):

      setup-interfaces && ifup eth0 && echo -en \"nameserver 8.8.8.8\" >> /etc/resolv.conf && wget https://raw.githubusercontent.com/ivam3/termux-packages/gh-pages/packages/termux-docker-qemu/ashrc.sh -O /etc/profile.d/ashrc.sh && wget https://raw.githubusercontent.com/ivam3/termux-packages/gh-pages/packages/termux-docker-qemu/answerfile.$os && sed -i 's/sda/vda/g' answerfile.$os && apk add tzdata && setup-$os -f answerfile.$os && poweroff
  
    press \e[33mENTER\e[0m to continue" && read enter

    # Boot it up with VirtIO and Entropy RNG
    qemu-system-x86_64 -machine q35 -m $mRAM -smp \
      cpus=$(nproc) -cpu qemu64,+avx,+avx2 -vga virtio -full-screen -usb \
      -device usb-tablet -device virtio-rng-pci \
      -drive if=pflash,format=raw,read-only=on,file=${PREFIX}/share/qemu/edk2-x86_64-code.fd \
      -netdev user,id=n1,net=${ip}0/24,dhcpstart=${ip}9,hostfwd=tcp::2222-:22 \
      -device virtio-net-pci,netdev=n1 \
      -virtfs local,path=${HOME}/.local/share/termux-docker-qemu/$os/termux2$os,mount_tag=termux2alpine,security_model=passthrough \
      -drive file=$os.qcow2,if=virtio,format=qcow2,cache=unsafe,discard=on \
      -cdrom $iso \
      -nographic 
  fi
}

update(){
  echo -en """
[!] **UPDATES**
 ╰➤ Optimized VirtIO drivers for Disk, Net and Entropy (Faster Docker)
 ╰➤ Native QCOW2 support
 ╰➤ Enable graphical enviroment with xfce4+vncserver
 ╰➤ Enable option to keep the image previous installed
 ╰➤ Port mapping between Termux & VM: 8080-:80,2222:22,2121:21,8000:8000,5900:5900
"""
}

echo "[?] Choose an Operative System:"
select os in alpine;do
  case $os in
    alpine)
      echo "[?] Choose an architecture [recommended x86_64]:" 
      select arch in x86 x86_64 aarch64 armv7;do
        m="$arch";break
      done
      
      echo "[?] Choose a version:"
      select v in "v3.16" "v3.17" "v3.18" "v3.19" "v3.20" "v3.21" "v3.22" "v3.23";do 
          case $v in 
              v3.16) iv="3.16.9";break ;;
              v3.17) iv="3.17.9";break ;;
              v3.18) iv="3.18.9";break ;;
              v3.19) iv="3.19.9";break ;;
              v3.20) iv="3.20.9";break ;;
              v3.21) iv="3.21.7";break ;;
              v3.22) iv="3.22.4";break ;;
              v3.23) iv="3.23.4";break ;;
              *) echo "Invalid version"; continue;;
          esac
      done
      declare ref=https://dl-cdn.alpinelinux.org/alpine/$v/releases/$m/
      declare iso=alpine-virt-$iv-$m.iso
      break
      ;;
    *) echo -en "\e[31mE:\e[0m wrong answer ... try again.\n"
      ;;
  esac
done

# Validate previous image
if [[ -e ${HOME}/.local/share/termux-docker-qemu/$os/$os.qcow2 ]]; then 
    echo -en "W: There is a previous $os image (.qcow2)\n╰─➤ Do you wanna overwrite it? [y/n]"
    while read -p ": " answ && [ -z $answ ]; do continue; done
    if [[ "$answ" =~ ^[Yy] ]]; then 
        echo "Deleting $os image."
        rm -f ${HOME}/.local/share/termux-docker-qemu/$os/$os.qcow2 
        install && update
    else 
        update
    fi
else
    install && update
fi

curl -fsSL \
  https://raw.githubusercontent.com/ivam3/termux-packages/gh-pages/packages/termux-docker-qemu/$os\X11.sh \
  -o ${HOME}/.local/share/termux-docker-qemu/$os/termux2$os/$os\X11.sh

echo ""
echo "[*] termux-docker-qemu installation finished (Optimized with VirtIO)."
echo "[📢] Help: https://t.me/Ivam3_Bot."
