#!/data/data/com.termux/files/usr/bin/bash
# COLORS
W="\e[0m"
R="\e[31m"
G="\e[32m"
Y="\e[33m"
B="\e[34m"
os="$1"
mRAM="12288"
DISPLAY=":0"
base_path="${HOME}/.local/share/termux-docker-qemu"
mnt="$base_path/$os/termux2$os"

[[ $# -eq 0 ]] && { 
  echo -en "\e[33mUsage:\e[0m termux-docker-qemu <operative system name> [x11]"
  exit 1
}

if [[ $2 == 'x11' ]]; then
    XorCLi="-vnc $DISPLAY"
    VGA="-vga virtio"
else
    XorCLi="-nographic"
    VGA="-vga none"
fi

if [[ -d "$base_path/$os" ]]; then
    cd "$base_path/$os"
    [[ -d "$mnt" ]] || mkdir -p "$mnt"
else
    echo -en $R"E:$W $(basename $0) PATH missing ...$Y Aborting.$W"
    exit 2
fi

if [[ -f "$os.qcow2" ]]; then
    DISK_IMG="$os.qcow2"
    DISK_FMT="qcow2"
else
    echo -e $R"E: No se encontró la imagen $os.qcow2$W"
    exit 4
fi

case "$os" in
  alpine)
      stty size > "$mnt/screen.txt" 2>/dev/null
      ipnet=$(ifconfig 2>/dev/null|grep -oE '([0-9]{1,3}\.){3}'|grep -v 255|grep -v 127|tail -n 1)
      [[ -z "$ipnet" ]] && ipnet="10.0.2."

      echo -e "$G[+] Iniciando Alpine (VirtIO Boost)$W"

      qemu-system-x86_64 \
          -machine q35 \
          -m $mRAM \
          -smp cpus=$(nproc) \
          -cpu qemu64,+avx,+avx2 \
          $VGA \
          -full-screen \
          -usb \
          -device usb-tablet \
          -device virtio-rng-pci \
          -drive if=pflash,format=raw,read-only=on,file=${PREFIX}/share/qemu/edk2-x86_64-code.fd \
          -device virtio-blk-pci,drive=drive0,bootindex=0 \
          -drive file="$DISK_IMG",if=none,id=drive0,format=$DISK_FMT,discard=on,cache=unsafe \
          -netdev user,id=n1,net=${ipnet}0/24,dhcpstart=${ipnet}9,hostfwd=tcp::8080-:80,hostfwd=tcp::2222-:22,hostfwd=tcp::2121-:21,hostfwd=tcp::8000-:8000,hostfwd=tcp::5900-:5900 \
          -device virtio-net-pci,netdev=n1 \
          -virtfs local,path="$mnt",mount_tag=termux2$os,security_model=passthrough \
          $XorCLi
      ;;
  *)
      echo "E: Invalid Operative System.. Aborting."
      exit 3
      ;;
esac
