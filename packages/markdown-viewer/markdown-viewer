#!/data/data/com.termux/files/usr/bin/bash
# COLORS
W="\e[0m"
R="\e[31m"
G="\e[32m"
Y="\e[33m"
B="\e[34m"
LPORT=4444 
LOOPBACK=127.0.0.1

! command -v nmap &> /dev/null && apt install nmap -y &> /dev/null

getPORT(){
        chk-pkg nmap nmap
        while [[ $(nmap -p$LPORT $LOOPBACK|grep "$LPORT"|awk -F " " '{print $2}') = "open" ]]
        do
                let LPORT=$LPORT+1
        done
}

if [[ -d ${HOME}/.local/share/markdown_viewer_app ]]
then
  cd ${HOME}/.local/share/markdown_viewer_app >/dev/null
  echo -en "(>_) Starting Markdown Viewer over : "
  flet run src/main.py -w -p $LPORT --host 0.0.0.0
else
  echo -en $R"E:$W $(basename $0) PATH missing ...$Y Aborting.$W"
  exit 1
fi
