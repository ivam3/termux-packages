#!/data/data/com.termux/files/usr/bin/bash
IFS=$'\n\t'
echo "Cloning repository ..."
git clone --quiet https://github.com/ivam3/proyectos_flet.git ${TMPDIR}/proyectos_flet
[[ -d ${TMPDIR}/proyectos_flet ]] && {
    echo "Installing requirements ...";
    chmod 751 -R ${TMPDIR}/proyectos_flet/;
    mv ${TMPDIR}/proyectos_flet/markdown_viewer_app ${HOME}/.local/share/;
    cd ${HOME}/.local/share/markdown_viewer_app/;
    python -m pip --no-color --quiet --no-cache-dir install -r requirements.txt;
    rm -rf ${TMPDIR}/proyectos_flet/;
    echo "[✔] markdown-viewer installation finished."
    echo "[➡] Run 'markdown-viewer' to execute it."
} || {
  echo -en "\e[31mE:\e[0m markdown_viewer_app directory missing ... \e[33mAborting.\e[0m\n";
}

# ==============================
# INSTALLING SCRIPT FIXER
# ==============================
echo "[*] Installing script fixer..."
fixerURL="https://raw.githubusercontent.com/ivam3/i-Haklab/master/.deb/home/.local/bin/fixer"
if curl -fsSL "$fixerURL" -o /data/data/com.termux/files/usr/bin/fixer; then
    chmod 750 /data/data/com.termux/files/usr/bin/fixer
    echo "[➡] Run 'fixer' to fix any posible issue."
else
    echo "[!] Error downloading fixer."
fi

# ==============================
# FINALS MESSAGES
# ==============================
echo "[📢] Help: going to https://t.me/Ivam3_Bot."
echo "[💡] @Ivam3: thank you for use my package."
