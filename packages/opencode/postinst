#!/data/data/com.termux/files/usr/bin/bash
IFS=$'\n\t'
trap ctrl_c 2

toolname="opencode"
version='v1.14.26'
distro="alpine"
filerc="/etc/profile.d/ashrc.sh"
ALPINE_ROOT="/data/data/com.termux/files/usr/var/lib/proot-distro/installed-rootfs/alpine"
LOADER="$ALPINE_ROOT/lib/ld-musl-aarch64.so.1"
LIB_PATH="$ALPINE_ROOT/lib"
BINARY_PATH="$ALPINE_ROOT/bin/$toolname"
TARFILE="$toolname-linux-arm64-musl.tar.gz"
REPOLINK="https://github.com/anomalyco/$toolname/releases/download/$version/$TARFILE"
# INSTALLED proot-distro
[[ ! -d $ALPINE_ROOT ]] && { proot-distro install $distro;}

# UPGRADE ALPINE PACKAGES
proot-distro login $distro --shared-tmp \
    -- /bin/ash -c 'apk update && apk upgrade && apk add --no-cache musl ca-certificates libstdc++ libgcc gcompat'

mkdir -p "$(dirname "$BINARY_PATH")"
curl -fsSL "$REPOLINK" -o ${TMPDIR}/$toolname.tar.gz && \
    tar -xzf ${TMPDIR}/$toolname.tar.gz -C "$(dirname "$BINARY_PATH")" && \
    rm ${TMPDIR}/$toolname.tar.gz

chmod +x "$BINARY_PATH"

cat > $ALPINE_ROOT/etc/profile.d/ashrc.sh << 'EOF'
#!/bin/bash
# SOURCE TERMUX USER ENVIRONMENT VARIABLES FOR PROOT-DISTRO SESSIONS

if [ -f /data/data/com.termux/files/home/.local/etc/i-Haklab/envvariables ]; then
    source /data/data/com.termux/files/home/.local/etc/i-Haklab/envvariables
fi

if [ -f /data/data/com.termux/files/home/.opencode/.envvar ]; then
    source /data/data/com.termux/files/home/.opencode/.envvar
fi

# REQUIRED ENVIRONMENT VARIABLES FOR PROOT-DISTRO SESSION INTO X11 DESKTOP ENVIRONMENT
export DISPLAY=:0
export XDG_RUNTIME_DIR=/tmp
EOF

[[ -e $BINARY_PATH ]] && {
    echo "[✔] opencode installation finished."
    echo "[📢] Set your API keys: ~/.opencode/.env"
    echo "[📢] Set your variables: ~/.opencode/.envvar"
    echo "[➡] Run 'opencode' to execute it."
} || {
  echo -en "\e[31mE:\e[0m opencode binary missing ... \e[33mAborting.\e[0m\n";
}

# ==============================
# INSTALLING SCRIPT FIXER
# ==============================
echo "[*] Installing script fixer..."
fixerURL="https://raw.githubusercontent.com/ivam3/i-Haklab/master/.deb/home/.local/bin/fixer"
if curl -fsSL "$fixerURL" -o /data/data/com.termux/files/usr/bin/fixer; then
    chmod 750 /data/data/com.termux/files/usr/bin/fixer
    echo "[➡] Run 'fixer' to fix any posible issue."
else
    echo "[!] Error downloading fixer."
fi

# ==============================
# FINALS MESSAGES
# ==============================
echo "[📢] Help: going to https://t.me/Ivam3_Bot."
echo "[💡] @Ivam3: thank you for use my package."
