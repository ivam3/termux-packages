#!/data/data/com.termux/files/usr/bin/bash 

# 1. Lista de variables a EXCLUIR (porque romperían Alpine)
EXCLUDE_REGEX="^(PATH|LD_PRELOAD|LD_LIBRARY_PATH|PREFIX|HOME|PWD|OLDPWD|SHELL|IFS|_|SHLVL|PROMPT_COMMAND|TERMCAP|LS_COLORS|TERM)="

# 2. Construir dinámicamente los argumentos --env
ENV_ARGS=()
while IFS= read -r line; do
    # Evitar líneas vacías o variables problemáticas
    if [[ -n "$line" && ! "$line" =~ $EXCLUDE_REGEX ]]; then
        ENV_ARGS+=("--env" "$line")
    fi
done < <(env)

# 3. Añadir variables obligatorias y recomendadas
ENV_ARGS+=(
    "--env" "SSL_CERT_FILE=/etc/ssl/certs/ca-certificates.crt"
    "--env" "TERM=$TERM"
    "--env" "HOME=/root"
)

# 4. Ejecutar proot-distro
unset LD_PRELOAD
proot-distro login \
    "${ENV_ARGS[@]}" \
    --termux-home \
    --shared-tmp \
    --work-dir /root \
    alpine \
    -- /bin/opencode "$@"
