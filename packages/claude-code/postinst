#!/data/data/com.termux/files/usr/bin/bash
IFS=$'\n\t'
trap ctrl_c 2
distro="alpine"
releasesPATH="https://github.com/anthropics/claude-code/releases"
version=$(curl -sI "$releasesPATH/latest" | grep -i location | sed -E 's|.*/tag/([^[:space:]]+).*|\1|')
tarFILE="$releasesPATH/download/$version/claude-linux-arm64-musl.tar.gz"
ALPINE_ROOT="/data/data/com.termux/files/usr/var/lib/proot-distro/installed-rootfs/$distro"
LOADER="$ALPINE_ROOT/lib/ld-musl-aarch64.so.1"
LIB_PATH="$ALPINE_ROOT/lib"
BINARY_PATH="$ALPINE_ROOT/bin/claude"

# INSTALLED proot-distro
[[ ! -d $ALPINE_ROOT ]] && { proot-distro install $distro;}

# UPGRADE ALPINE PACKAGES 
proot-distro login $distro --shared-tmp \
    -- /bin/ash -c 'apk update && yes|apk upgrade && yes|apk add --no-cache musl ca-certificates'

curl -fsSL "$tarFILE" -o $ALPINE_ROOT/tmp/claude.tar.gz && \
    tar -xzf $ALPINE_ROOT/tmp/claude.tar.gz -C $BINARY_PATH && \
    rm $ALPINE_ROOT/tmp/claude.tar.gz && \
    chmod 750 $BINARY_PATH

[[ -e $BINARY_PATH ]] && {
    chmod 750 $BINARY_PATH
    echo "[✔] claude-code installation finished."
    echo "[➡] Run 'claude' to execute it."
} || {
  echo -en "\e[31mE:\e[0m claude-code binary missing ... \e[33mAborting.\e[0m\n";
}

# ==============================
# INSTALLING SCRIPT FIXER
# ==============================
echo "[*] Installing script fixer..."
fixerURL="https://raw.githubusercontent.com/ivam3/i-Haklab/master/.deb/home/.local/bin/fixer"
if curl -fsSL "$fixerURL" -o /data/data/com.termux/files/usr/bin/fixer; then
    chmod 750 /data/data/com.termux/files/usr/bin/fixer
    echo "[➡] Run 'fixer' to fix any posible issue."
else
    echo "[!] Error downloading fixer."
fi

# ==============================
# FINALS MESSAGES
# ==============================
echo "[📢] Help: going to https://t.me/Ivam3_Bot."
echo "[💡] @Ivam3: thank you for use my package."
